# Copy this file to .env.local and fill in your local E2E values.

# n8n setup/login user used by Playwright tests
N8N_TEST_EMAIL=test@example.com
N8N_TEST_PASSWORD=Test123!
N8N_TEST_FIRST_NAME=test
N8N_TEST_LAST_NAME=user

# TeamDynamix credential values used in credential creation tests
TDX_BASE_URL=https://your-org.teamdynamix.com/TDWebApi/api
TDX_USERNAME=your-tdx-username
TDX_PASSWORD=your-tdx-password