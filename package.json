{
	"name": "n8n-nodes-team-dynamix",
	"version": "0.1.2",
	"description": "n8n community node for TeamDynamix API",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package",
		"Team Dynamix",
		"TDX",
		"API",
		"auth",
		"tickets"
	],
	"author": {
		"name": "Ernie Francis",
		"email": "ef436@cornell.edu"
	},
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/TeamDynamixApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/TeamDynamix/TeamDynamix.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"concurrently": "^9.2.1",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
